# SentriX Environment Configuration
# Copy this file to .env and fill in your values

# Security
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# Wazuh SIEM Integration
WAZUH_URL=https://your-wazuh-server:55000
WAZUH_USER=wazuh
WAZUH_PASSWORD=your-wazuh-password
WAZUH_ENABLED=false

# TheHive SOAR Integration
THEHIVE_URL=http://your-thehive-server:9000
THEHIVE_API_KEY=your-thehive-api-key
THEHIVE_ENABLED=false

# Cortex (used with TheHive)
CORTEX_URL=http://your-cortex-server:9001
CORTEX_API_KEY=your-cortex-api-key
CORTEX_ENABLED=false

# VirusTotal Threat Intelligence
# Get free API key at: https://www.virustotal.com
VIRUSTOTAL_API_KEY=your-virustotal-api-key
VIRUSTOTAL_ENABLED=false

# OpenAI / AI Engine (for full RAG capabilities)
# Get API key at: https://platform.openai.com
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
AI_ENABLED=false
